{
  "name": "lookbook-mcp",
  "display_name": "Lookbook",
  "description": "Lookbook — design taste for any LLM. An MCP server + unbounded packet compiler that routes a frontend brief through a curated, hand-authored design library and returns complete relevance-selected source, layout direction, constraints, and anti-copy rules.",
  "status": "mcp-server-implemented",
  "canonical_source": "src/design_router_mcp",
  "canonical_source_note": "See CANONICAL_SOURCE.md. src_rebuild/ and rebuild_package/ are deprecated legacy mirrors.",
  "tools": [
    {
      "name": "resolve_design_context",
      "kind": "mcp_tool",
      "input": "DesignContextRequest JSON",
      "output": "RenderedPacket markdown",
      "transport": "stdio"
    },
    { "name": "inspect_design_library", "kind": "mcp_tool" },
    { "name": "get_pattern_card", "kind": "mcp_tool" },
    { "name": "get_source_excerpt", "kind": "mcp_tool" },
    { "name": "export_opencode_bundle", "kind": "mcp_tool" },
    { "name": "route_alternatives", "kind": "mcp_tool" },
    { "name": "donor_starvation_audit", "kind": "mcp_tool" },
    { "name": "code_density_metrics", "kind": "mcp_tool" },
    { "name": "audit_source_hygiene", "kind": "mcp_tool" },
    { "name": "validate_design_router", "kind": "mcp_tool" }
  ],
  "deprecated_tool_names": [
    "design_context_resolve",
    "list_design_packs",
    "get_pattern_summary",
    "get_minimal_code",
    "get_preview_images"
  ],
  "cli": {
    "packet_cli": "lookbook",
    "mcp_cli": "lookbook-mcp",
    "legacy_packet_cli": "design-router-gpt-5.5-packet",
    "legacy_mcp_cli": "design-router-gpt-5.5-mcp"
  }
}
