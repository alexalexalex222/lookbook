# --------------------------------------------------------------------------
# user_message augment: optional raw-user-message signal folded into the
# scored token bag (route/resolve). Default-off; only synthesized corpora are
# used so the assertions do not depend on the live corpus's evolving content.

WEAK_BRIEF = "help me with this thing"


def test_user_message_augment_fixes_a_weak_brief_that_abstains_alone(tmp_path):
    _write_matching_corpus(tmp_path)
    router = KnowledgeRouter(tmp_path)
    alone = router.route(WEAK_BRIEF, k=1)
    assert alone.get("abstain") is True, "a poor brief-summary alone must abstain (no lexical match)"
    augmented = router.route(WEAK_BRIEF, k=1, user_message=PLAIN_MATCH_BRIEF)
    assert not augmented.get("abstain"), "raw user text folded in must recover a route"
    assert augmented["picks"], "augmented route must produce at least one pick"
    assert augmented["picks"][0][0] == "demo-topic-alpha", (
        "augmented picks must land on the topic the raw user text actually names"
    )


def test_user_message_empty_is_byte_identical_to_omitted(router):
    for brief in (RETRY_BRIEF, B27_BRIEF, NONSENSE_BRIEF):
        assert router.route(brief, k=2) == router.route(brief, k=2, user_message="")
        assert router.resolve(brief, k=2) == router.resolve(brief, k=2, user_message="")
