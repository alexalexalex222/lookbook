def test_mcp_server_registers_knowledge_tools():
    import asyncio

    from design_router_mcp import mcp_server

    try:
        server = mcp_server.create_mcp_server(Path(__file__).resolve().parents[1])
    except mcp_server.MissingMcpDependencyError:
        pytest.skip("optional mcp dependency not installed")
    tool_names = {tool.name for tool in asyncio.run(server.list_tools())}
    assert "resolve_knowledge_context" in tool_names
    assert "validate_knowledge_router" in tool_names
    # existing design tools must be untouched
    assert "resolve_design_context" in tool_names
    assert "validate_design_router" in tool_names


# --------------------------------------------------------------------------
# Below: synthetic-corpus and monkeypatch tests added to close named test
# gaps (standard-mode raw-source gating, real lane-guard demotion, boundary
# floors, the L359-361 dead-branch, and the packet header). Synthetic corpora
# are used instead of the live goldenbook-harvest corpus so scores/picks are
# not sensitive to its (independently evolving) content.

RETRY_BRIEF = (
    "Design the retry policy for a payment service that calls a card processor: "
    "timeouts, retry counts, exponential backoff, and jitter at every hop."
)


def _write_standard_mode_corpus(root: Path) -> None:
    (root / "playbooks").mkdir(parents=True)
    (root / "raw").mkdir()
    (root / "playbooks" / "demo-topic-alpha.md").write_text(
        "---\ntitle: demo topic alpha\n---\n"
        "# Demo Topic Alpha\n\n"
        "This playbook covers demo topic alpha guidance for widgets and gadgets galore.\n\n"
        "## Sources\n"
        "- raw/good1.md\n- raw/good2.md\n- raw/good3.md\n- raw/good4.md\n"
        "- raw/tierb.md\n- raw/reject.md\n"
    )
    for n in ("good1", "good2", "good3", "good4"):
        (root / "raw" / f"{n}.md").write_text(
            f"---\ntier: A\n---\nRaw source body text for {n} about demo topic alpha guidance.\n"
        )
    (root / "raw" / "tierb.md").write_text(
        "---\ntier: B\n---\nLower-tier material, not eligible for standard mode.\n"
    )
    (root / "raw" / "reject.md").write_text(
        "---\ntier: A\n---\nREJECT: this source has been superseded and must not be cited.\n"
    )
    # A second, vocabulary-disjoint playbook is required: with only one
    # playbook in the corpus every one of its tokens has document frequency
    # equal to the corpus size, so idf collapses to 0 and every score is 0.
    (root / "playbooks" / "unrelated-decoy-zeta.md").write_text(
        "---\ntitle: unrelated decoy zeta\n---\n# Unrelated Decoy Zeta\n\n"
        "oceans rivers mountains valleys canyons deserts\n"
    )


def test_standard_mode_filters_by_tier_rejects_and_caps_at_three(tmp_path):
    _write_standard_mode_corpus(tmp_path)
    router = KnowledgeRouter(tmp_path)
    brief = "Explain the demo topic alpha guidance for widgets and gadgets."
    result = router.resolve(brief, mode="standard", k=1)
    assert not result.get("abstain")
    assert [name for name, _ in result["picks"]] == ["demo-topic-alpha"]
    excerpts = [line for line in result["packet"].splitlines()
                if line.startswith("[source excerpt:")]
    assert excerpts == [
        "[source excerpt: raw/good1.md]",
        "[source excerpt: raw/good2.md]",
        "[source excerpt: raw/good3.md]",
    ]
    # `excerpts` above already pins the exact 3-item set (good1-3 only), which
    # proves the 3-excerpt cap, the tier-B exclusion, and the REJECT exclusion
    # all at once: good4/tierb/reject are tier-A-eligible-or-not but none made
    # the final list.


def _write_lane_guard_demotion_corpus(root: Path) -> None:
    (root / "playbooks").mkdir(parents=True)
    (root / "raw" / "agentic").mkdir(parents=True)
    (root / "raw" / "backend").mkdir(parents=True)
    (root / "raw" / "agentic" / "x.md").write_text("agentic source\n")
    (root / "raw" / "backend" / "y.md").write_text("backend source\n")
    shared = "widget gadget sprocket bracket lever pulley gizmo contraption apparatus mechanism"
    (root / "playbooks" / "aaa-zephyr-solo.md").write_text(
        f"---\ntitle: aaa zephyr solo\n---\n# Aaa Zephyr Solo\n\n{shared}\n\n"
        "## Sources\n- raw/agentic/x.md\n"
    )
    for nm in ("bbb-gamma-one", "bbb-gamma-two", "bbb-gamma-three"):
        (root / "playbooks" / f"{nm}.md").write_text(
            f"---\ntitle: {nm}\n---\n# {nm}\n\n{shared}\n\n"
            "## Sources\n- raw/backend/y.md\n"
        )
    (root / "playbooks" / "zzz-decoy-neutral.md").write_text(
        "---\ntitle: zzz decoy neutral\n---\n# Zzz Decoy Neutral\n\n"
        "oceans rivers mountains valleys canyons deserts glaciers volcanoes islands peninsulas\n"
    )


def test_lane_guard_real_demotion_sets_metadata_fields(tmp_path):
    # A single agentic-lane doc ties (by shared vocabulary) with three
    # backend-lane docs and wins the tie-break on name alone, so it is the top
    # pick — but the backend lane's combined top-5 mass is 3x the agentic
    # lane's, so the mass-fallback lane inference calls the brief "backend"
    # and the guard must demote the agentic top pick with no name-token veto.
    _write_lane_guard_demotion_corpus(tmp_path)
    router = KnowledgeRouter(tmp_path)
    brief = "widget gadget sprocket bracket lever pulley gizmo contraption apparatus mechanism"
    result = router.route(brief, k=2)
    assert not result.get("abstain")
    lane_info = result["lane_inference"]
    assert lane_info["guard_triggered"] is True
    assert lane_info["demoted_top_pick"] == "aaa-zephyr-solo"
    assert lane_info["name_token_veto"] == []
    assert lane_info["top_pick_lane"] == "agentic"
    assert lane_info["brief_lane"] == "backend"
    assert result["picks"]
    for name, _score in result["picks"]:
        assert router.lanes[name] == "backend"


def test_min_score_floor_excludes_a_trailing_pick(router, monkeypatch):
    # This probes the LEXICAL floor mechanism, where pick order == top5 order.
    # Disable the optional semantic re-rank (which intentionally reorders picks
    # away from lexical order) so the probe isolates MIN_SCORE.
    monkeypatch.setattr(router, "_emb", {})
    # result["top5"] / result["picks"] are both (name, score) pairs.
    baseline = router.route(RETRY_BRIEF, k=5)
    top5 = baseline["top5"]
    assert len(top5) >= 3, "need >= 3 ranked docs to isolate the MIN_SCORE floor"
    assert len(baseline["picks"]) >= 3 and baseline["picks"][2][0] == top5[2][0], (
        "3rd top5 doc must survive under default gates so this probe isolates MIN_SCORE"
    )
    second_score, third_score = top5[1][1], top5[2][1]
    assert third_score < second_score, "top5 scores must be strictly descending for this probe"
    forced_floor = (second_score + third_score) / 2
    monkeypatch.setattr(knowledge_router, "MIN_SCORE", forced_floor)
    forced = router.route(RETRY_BRIEF, k=5)
    assert [name for name, _ in forced["picks"]] == [name for name, _ in baseline["picks"][:2]]


def test_second_pick_ratio_floor_excludes_a_trailing_pick(router, monkeypatch):
    # Lexical-mechanism probe: disable semantic re-rank so pick order == top5 order.
    monkeypatch.setattr(router, "_emb", {})
    baseline = router.route(RETRY_BRIEF, k=5)
    top5 = baseline["top5"]
    assert len(top5) >= 2, "need >= 2 ranked docs to isolate the SECOND_PICK_RATIO floor"
    assert len(baseline["picks"]) >= 2 and baseline["picks"][1][0] == top5[1][0], (
        "2nd top5 doc must survive under default gates so this probe isolates the ratio"
    )
    first_score, second_score = top5[0][1], top5[1][1]
    forced_ratio = min((second_score / first_score) + 0.05, 0.99)
    monkeypatch.setattr(knowledge_router, "SECOND_PICK_RATIO", forced_ratio)
    forced = router.route(RETRY_BRIEF, k=5)
    assert [name for name, _ in forced["picks"]] == [top5[0][0]]


def test_no_pick_above_relevance_floor_branch_reachable_via_monkeypatch(router, monkeypatch):
    # Under the shipped constants this branch is structurally unreachable:
    # MIN_SCORE (0.06) < HARD_FLOOR (0.10), and the abstain gates above the
    # picks loop guarantee best >= HARD_FLOOR, so pool[0][0] >= MIN_SCORE
    # always holds and the loop always appends at least one pick. Monkeypatch
    # MIN_SCORE above the live top score to prove the line is live code, not
    # unreachable dead code.
    baseline = router.route(RETRY_BRIEF, k=2)
    assert baseline["picks"], "need a routable brief to reach the picks loop"
    top_score = baseline["top5"][0][1]
    monkeypatch.setattr(knowledge_router, "MIN_SCORE", top_score + 0.1)
    forced = router.route(RETRY_BRIEF, k=2)
    assert forced.get("abstain") is True
    assert forced["picks"] == []
    assert "relevance floor" in forced["reason"]


